{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://civilization-os.example/schemas/civilization-os-interoperability-profile.schema.json",
  "title": "Civilization OS Interoperability Profile",
  "description": "Defines ordered protocol bindings through canonical identifier, compatibility, and adapter registries, together with resolution receipt and conformance handoff policies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_kind",
    "profile_id",
    "status",
    "title",
    "description",
    "identifier_namespace",
    "identifier_registry",
    "compatibility_registry",
    "adapter_registry",
    "adapter_bindings",
    "resolution_policy",
    "profile_sequence",
    "conformance"
  ],
  "properties": {
    "schema_version": {
      "const": "0.5.0"
    },
    "profile_kind": {
      "const": "civilization-os-interoperability-profile"
    },
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 128
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "identifier_namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9-]+)+$"
    },
    "identifier_registry": {
      "$ref": "#/$defs/registryReference"
    },
    "compatibility_registry": {
      "$ref": "#/$defs/registryReference"
    },
    "adapter_registry": {
      "$ref": "#/$defs/registryReference"
    },
    "adapter_bindings": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/adapterBinding"
      }
    },
    "resolution_policy": {
      "$ref": "#/$defs/resolutionPolicy"
    },
    "profile_sequence": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/profileBinding"
            },
            {
              "properties": {
                "stage": {
                  "const": "origin"
                },
                "position": {
                  "const": 1
                }
              },
              "required": [
                "stage",
                "position"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profileBinding"
            },
            {
              "properties": {
                "stage": {
                  "const": "trace"
                },
                "position": {
                  "const": 2
                }
              },
              "required": [
                "stage",
                "position"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profileBinding"
            },
            {
              "properties": {
                "stage": {
                  "const": "authorization"
                },
                "position": {
                  "const": 3
                }
              },
              "required": [
                "stage",
                "position"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profileBinding"
            },
            {
              "properties": {
                "stage": {
                  "const": "execution"
                },
                "position": {
                  "const": 4
                }
              },
              "required": [
                "stage",
                "position"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profileBinding"
            },
            {
              "properties": {
                "stage": {
                  "const": "audit"
                },
                "position": {
                  "const": 5
                }
              },
              "required": [
                "stage",
                "position"
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/profileBinding"
            },
            {
              "properties": {
                "stage": {
                  "const": "royalty"
                },
                "position": {
                  "const": 6
                }
              },
              "required": [
                "stage",
                "position"
              ]
            }
          ]
        }
      ],
      "items": false
    },
    "conformance": {
      "$ref": "#/$defs/conformancePolicy"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "registryReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_id",
        "version",
        "registry_ref"
      ],
      "properties": {
        "registry_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 128
        },
        "version": {
          "$ref": "#/$defs/versionString"
        },
        "registry_ref": {
          "$ref": "#/$defs/fileReference"
        }
      }
    },
    "profileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "position",
        "protocol",
        "consumes",
        "produces"
      ],
      "properties": {
        "stage": {
          "$ref": "#/$defs/stageName"
        },
        "position": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "protocol": {
          "$ref": "#/$defs/protocolReference"
        },
        "consumes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/consumedIdentifier"
          }
        },
        "produces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/producedIdentifier"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "protocolReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_id",
        "version",
        "repository",
        "schema_ref",
        "record_type"
      ],
      "properties": {
        "protocol_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 160
        },
        "version": {
          "$ref": "#/$defs/versionString"
        },
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
          "maxLength": 300
        },
        "schema_ref": {
          "$ref": "#/$defs/fileReference"
        },
        "record_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 160
        }
      }
    },
    "consumedIdentifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_id",
        "from_stage",
        "local_field",
        "required"
      ],
      "properties": {
        "canonical_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "from_stage": {
          "$ref": "#/$defs/stageName"
        },
        "local_field": {
          "$ref": "#/$defs/localField"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "producedIdentifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_id",
        "local_field"
      ],
      "properties": {
        "canonical_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        },
        "local_field": {
          "$ref": "#/$defs/localField"
        }
      }
    },
    "adapterBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "adapter_id",
        "adapter_version",
        "source_stage",
        "target_stage",
        "canonical_id"
      ],
      "properties": {
        "binding_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 160
        },
        "adapter_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 160
        },
        "adapter_version": {
          "$ref": "#/$defs/versionString"
        },
        "source_stage": {
          "$ref": "#/$defs/stageName"
        },
        "target_stage": {
          "$ref": "#/$defs/stageName"
        },
        "canonical_id": {
          "$ref": "#/$defs/canonicalIdentifier"
        }
      }
    },
    "resolutionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_resolution_receipt",
        "require_digest_lock",
        "require_exact_stage_snapshot",
        "require_conformance_handoff",
        "handoff_target"
      ],
      "properties": {
        "require_resolution_receipt": {
          "const": true
        },
        "require_digest_lock": {
          "const": true
        },
        "require_exact_stage_snapshot": {
          "const": true
        },
        "require_conformance_handoff": {
          "const": true
        },
        "handoff_target": {
          "const": "kazene-protocol-conformance-suite"
        }
      }
    },
    "conformancePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_ordered_execution",
        "require_reference_resolution",
        "require_registry_resolution",
        "require_registered_identifiers",
        "require_unique_contract_producers",
        "require_compatibility_resolution",
        "require_exact_protocol_versions",
        "reject_blocked_compatibility",
        "require_adapter_resolution",
        "reject_unbound_adapters",
        "reject_lossy_adapters",
        "require_resolution_receipt",
        "require_digest_lock",
        "require_conformance_handoff",
        "reject_unknown_stages",
        "allow_optional_profiles"
      ],
      "properties": {
        "require_ordered_execution": {
          "const": true
        },
        "require_reference_resolution": {
          "const": true
        },
        "require_registry_resolution": {
          "const": true
        },
        "require_registered_identifiers": {
          "const": true
        },
        "require_unique_contract_producers": {
          "const": true
        },
        "require_compatibility_resolution": {
          "const": true
        },
        "require_exact_protocol_versions": {
          "const": true
        },
        "reject_blocked_compatibility": {
          "const": true
        },
        "require_adapter_resolution": {
          "const": true
        },
        "reject_unbound_adapters": {
          "const": true
        },
        "reject_lossy_adapters": {
          "type": "boolean"
        },
        "require_resolution_receipt": {
          "const": true
        },
        "require_digest_lock": {
          "const": true
        },
        "require_conformance_handoff": {
          "const": true
        },
        "reject_unknown_stages": {
          "const": true
        },
        "allow_optional_profiles": {
          "type": "boolean"
        }
      }
    },
    "stageName": {
      "type": "string",
      "enum": [
        "origin",
        "trace",
        "authorization",
        "execution",
        "audit",
        "royalty"
      ]
    },
    "canonicalIdentifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_id$",
      "minLength": 3,
      "maxLength": 160
    },
    "localField": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*$",
      "minLength": 1,
      "maxLength": 300
    },
    "versionString": {
      "type": "string",
      "pattern": "^v?[0-9]+\\.[0-9]+(?:\\.[0-9]+)?$"
    },
    "fileReference": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)+$",
      "minLength": 3,
      "maxLength": 500
    }
  }
}
